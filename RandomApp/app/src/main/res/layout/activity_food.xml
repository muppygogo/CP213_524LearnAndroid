<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootFoodPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7E5EC">

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/navHomeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="#A38290"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="หน้าแรก"
                android:textColor="#8A7480"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navName"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/navNameIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☺"
                android:textColor="#A38290"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ชื่อ"
                android:textColor="#8A7480"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNumber"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/navNumberIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◉"
                android:textColor="#A38290"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navNumberText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ตัวเลข"
                android:textColor="#8A7480"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFood"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/navFoodIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕"
                android:textColor="#A38290"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navFoodText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="อาหาร"
                android:textColor="#8A7480"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/navProfileIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◌"
                android:textColor="#A38290"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navProfileText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="โปรไฟล์"
                android:textColor="#8A7480"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:id="@+id/foodScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavBar"
        android:background="#F7E5EC"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_food_header"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_back_pill"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="←  กลับ"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="52dp" />

                <TextView
                    android:id="@+id/headerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="สุ่มอาหาร"
                    android:textColor="#44333E"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/headerSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="ให้ AI ช่วยเลือกเมนูให้คุณ"
                    android:textColor="#6B6583"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/cardWheelMode"
                    android:layout_width="0dp"
                    android:layout_height="205dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_mode_card_pink"
                    android:gravity="top"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/wheelModeIcon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_icon_soft_pink"
                        android:gravity="center"
                        android:text="↻"
                        android:textColor="#E45683"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/wheelModeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="วงล้อสุ่ม"
                        android:textColor="#3B2C35"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/wheelModeSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="ใส่เมนูเองแล้วให้วงล้อเลือก"
                        android:textColor="#6C5863"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardAiMode"
                    android:layout_width="0dp"
                    android:layout_height="205dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_mode_card_blue"
                    android:gravity="top"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/aiModeIcon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_icon_soft_blue"
                        android:gravity="center"
                        android:text="◔"
                        android:textColor="#7962AE"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/aiModeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="AI แนะนำ"
                        android:textColor="#3B2C35"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/aiModeSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="บอก AI แล้วให้ช่วยหาร้าน"
                        android:textColor="#6C5863"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mainFoodCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="18dp"
                android:background="@drawable/bg_main_white_card"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_dot_blue" />

                    <TextView
                        android:id="@+id/sectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="เมนูของคุณ"
                        android:textColor="#725A68"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtFoodName"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_food"
                        android:hint="เพิ่มชื่ออาหาร"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#4A3942"
                        android:textColorHint="#A17F8E"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnAddFood"
                        android:layout_width="88dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="10dp"
                        android:backgroundTint="#E88CA5"
                        android:text="เพิ่ม"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/menuListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="190dp"
                    android:background="@drawable/bg_menu_box"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/menuListText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:textColor="#9A7484"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/emptyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ยังไม่มีเมนู"
                        android:textColor="#9A7484"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <com.example.randomapp.FoodWheelView
                    android:id="@+id/wheelView"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="30dp" />

                <Button
                    android:id="@+id/btnSpin"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_spin_button"
                    android:text="หมุนวงล้อ"
                    android:textColor="#3D2F39"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="#6B4D5D"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>